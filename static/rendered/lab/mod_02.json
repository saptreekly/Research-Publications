    {
      "kind": {
        "Blueprint": {
          "id": "powermod_impl",
          "language": "julia",
          "code": "\nfunction manual_powermod(a, k, m)\n    result = 1\n    base   = a % m\n    e      = k\n\n    while e > 0\n        if isodd(e)\n            result = (result * base) % m\n        end\n        base = (base * base) % m\n        e    = div(e, 2)\n    end\n\n    return result\nend\n\na, k, m = 3, 13, 97\nprintln(manual_powermod(a, k, m))\nprintln(powermod(a, k, m))"
        }
      },
