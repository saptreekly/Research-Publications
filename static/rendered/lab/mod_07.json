          "id": "rsa_keygen",
          "language": "julia",
          "code": "\nusing Primes\n\np, q = 61, 53\nn = p * q\nphi_n = (p - 1) * (q - 1)\ne = 7\nd = invmod(e, phi_n)\n\nprintln(\"n = $n\")\nprintln(\"phi(n) = $phi_n\")\nprintln(\"d = $d\")\nprintln((e * d) % phi_n)  # should be 1"
        }
