      "kind": {
        "Brief": {
          "id": "theory",
          "title": "Theory:",
          "brief_html": "<p>Choose distinct primes $p, q$. Set $n = pq$ and $\\phi(n) = (p-1)(q-1)$. Pick $e$ with $\\gcd(e, \\phi(n)) = 1$. Compute $d = e^{-1} \\pmod{\\phi(n)}$.</p>\n<p>Public key: $(e, n)$. Private key: $(d, n)$.</p>\n"
        }
      },
