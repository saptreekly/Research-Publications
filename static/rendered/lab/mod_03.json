    {
      "kind": {
        "Blueprint": {
          "id": "crt_impl",
          "language": "julia",
          "code": "\nfunction crt_two(r1, m1, r2, m2)\n    N = m1 * m2\n    N1 = N ÷ m1\n    N2 = N ÷ m2\n    x = (r1 * N1 * invmod(N1, m1) + r2 * N2 * invmod(N2, m2)) % N\n    return x\nend\n\nprintln(crt_two(2, 3, 3, 5))  # x = 8\nprintln(8 % 3, 8 % 5)"
        }
      },
