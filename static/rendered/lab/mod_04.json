      "kind": {
        "Brief": {
          "id": "theory",
          "title": "Theory:",
          "brief_html": "<p><strong>Fermat's Little Theorem:</strong> If $p$ is prime and $\\gcd(a,p)=1$, then $a^{p-1} \\equiv 1 \\pmod p$.</p>\n<p><strong>Euler's Theorem:</strong> If $\\gcd(a,n)=1$, then $a^{\\phi(n)} \\equiv 1 \\pmod n$, where $\\phi(n)$ counts integers in $[1,n)$ coprime to $n$.</p>\n<p>For prime $p$, $\\phi(p)=p-1$, recovering Fermat.</p>\n"
        }
      },
      "execution": {
