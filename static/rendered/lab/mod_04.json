    {
      "kind": {
        "Blueprint": {
          "id": "euler_impl",
          "language": "julia",
          "code": "\nfunction euler_phi(n)\n    count = 0\n    for i in 1:n-1\n        if gcd(i, n) == 1\n            count += 1\n        end\n    end\n    return count\nend\n\nfunction fermat_check(a, p)\n    return powermod(a, p - 1, p)\nend\n\nprintln(euler_phi(10))       # 4\nprintln(fermat_check(3, 7))  # 1"
        }
