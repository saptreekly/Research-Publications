    {
      "kind": {
        "Blueprint": {
          "id": "sieve_impl",
          "language": "julia",
          "code": "\nfunction sieve(n)\n    is_prime = fill(true, n + 1)\n    is_prime[1] = false\n\n    for i in 2:n\n        if is_prime[i] && i * i <= n\n            for j in i*i:i:n\n                is_prime[j] = false\n            end\n        end\n    end\n\n    return [i for i in 1:n if is_prime[i]]\nend\n\nfunction is_prime(n)\n    n >= 2 && n in sieve(n)\nend\n\nprintln(sieve(30))\nprintln(is_prime(17), is_prime(10))"
        }
